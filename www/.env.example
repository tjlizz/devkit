NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-side only: where Next.js rewrites proxy /api/* to (the Go API).
API_PROXY_TARGET=http://localhost:8080
# Optional: override the browser-side API base URL. Leave unset to use
# same-origin /api via the proxy above (recommended, avoids CORS).
# NEXT_PUBLIC_API_URL=
