# Optional YAML configuration file. Relative paths resolve from server/ when
# commands are run through the Makefile.
DEVKIT_CONFIG=

# Go API
DEVKIT_PORT=8080
DEVKIT_DB_PATH=./devkit.db

# SMTP (activation emails)
DEVKIT_SMTP_HOST=
DEVKIT_SMTP_PORT=587
DEVKIT_SMTP_USERNAME=
DEVKIT_SMTP_PASSWORD=
DEVKIT_SMTP_FROM=

# Vue/Vite
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:8080

# Next.js (www) — server-side proxy target for /api/*
API_PROXY_TARGET=http://localhost:8080
